)

[h4_bull_cnt, h4_bear_cnt, h4_in_bull, h4_in_bear, h4_bull_metric, h4_bear_metric, h4_bull_ref, h4_bear_ref, h4_bull_surv_best, h4_bear_surv_best, h4_bull_fill_best, h4_bear_fill_best, h4_bull_touch_best, h4_bear_touch_best] = f_update_zones(
    h4_boxes, h4_tops, h4_bottoms, h4_dirs, h4_flips, h4_born_times, h4_fills, h4_touches, h4_initq, h4_surv,
    h4_bull_bg, h4_bear_bg, h4_bull_bd, h4_bear_bd, h4_bull_txt, h4_bear_txt, "4H", 1,
    use_close_flip, h4_right_time, h4_expire_ms, show_zone_text
)

[d_bull_cnt, d_bear_cnt, d_in_bull, d_in_bear, d_bull_metric, d_bear_metric, d_bull_ref, d_bear_ref, d_bull_surv_best, d_bear_surv_best, d_bull_fill_best, d_bear_fill_best, d_bull_touch_best, d_bear_touch_best] = f_update_zones(
