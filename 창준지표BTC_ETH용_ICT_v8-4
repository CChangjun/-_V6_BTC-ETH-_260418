//=====================================================
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
atr_val = ta.atr(atr_len)
vol_ma = ta.sma(volume, vol_len)

range_hi = ta.highest(high, dealing_range_len)
range_lo = ta.lowest(low, dealing_range_len)
eq_line = (range_hi + range_lo) * 0.5
in_discount = close < eq_line
