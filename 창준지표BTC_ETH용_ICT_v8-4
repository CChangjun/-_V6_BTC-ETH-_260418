         style=label.style_label_up,
         textcolor=color.white,
         color=color.new(color.green, 0)
     )

if show_big_labels and short_signal
    _short_mode = short_mode_reversal ? "REV" : short_mode_continuation ? "CONT" : "NA"
    _short_score = short_mode_reversal ? short_reversal_score : short_continuation_score
    label.new(
         bar_index,
         high,
         "SHORT " + _short_mode +
         "\nScore: " + str.tostring(_short_score, "#.##") +
         "\nSurv: " + str.tostring(bear_zone_quality, "#.##") +
