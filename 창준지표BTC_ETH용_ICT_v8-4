    d_bull_bg, d_bear_bg, d_bull_bd, d_bear_bd, d_bull_txt, d_bear_txt, "1D", 2,
    use_close_flip, d_right_time, d_expire_ms, show_zone_text
)

bull_zone_count = ctf_bull_cnt + h4_bull_cnt + d_bull_cnt
bear_zone_count = ctf_bear_cnt + h4_bear_cnt + d_bear_cnt

any_bull_touch = ctf_in_bull or h4_in_bull or d_in_bull
any_bear_touch = ctf_in_bear or h4_in_bear or d_in_bear

near_bull_metric_all = f_min_valid(ctf_bull_metric, h4_bull_metric, d_bull_metric)
near_bear_metric_all = f_min_valid(ctf_bear_metric, h4_bear_metric, d_bear_metric)

near_bull_ref_all = f_pick_by_min_metric(ctf_bull_metric, ctf_bull_ref, h4_bull_metric, h4_bull_ref, d_bull_metric, d_bull_ref)
near_bear_ref_all = f_pick_by_min_metric(ctf_bear_metric, ctf_bear_ref, h4_bear_metric, h4_bear_ref, d_bear_metric, d_bear_ref)

near_bull_surv_all = f_pick_by_min_metric(ctf_bull_metric, ctf_bull_surv_best, h4_bull_metric, h4_bull_surv_best, d_bull_metric, d_bull_surv_best)
near_bear_surv_all = f_pick_by_min_metric(ctf_bear_metric, ctf_bear_surv_best, h4_bear_metric, h4_bear_surv_best, d_bear_metric, d_bear_surv_best)

near_bull_fill_all = f_pick_by_min_metric(ctf_bull_metric, ctf_bull_fill_best, h4_bull_metric, h4_bull_fill_best, d_bull_metric, d_bull_fill_best)
near_bear_fill_all = f_pick_by_min_metric(ctf_bear_metric, ctf_bear_fill_best, h4_bear_metric, h4_bear_fill_best, d_bear_metric, d_bear_fill_best)

near_bull_touches_all = f_pick_by_min_metric(ctf_bull_metric, ctf_bull_touch_best, h4_bull_metric, h4_bull_touch_best, d_bull_metric, d_bull_touch_best)
near_bear_touches_all = f_pick_by_min_metric(ctf_bear_metric, ctf_bear_touch_best, h4_bear_metric, h4_bear_touch_best, d_bear_metric, d_bear_touch_best)

bull_zone_quality = nz(near_bull_surv_all, 0.0)
bear_zone_quality = nz(near_bear_surv_all, 0.0)

bull_proximity = not na(near_bull_metric_all) and near_bull_metric_all <= atr_val * zone_proximity_atr
bear_proximity = not na(near_bear_metric_all) and near_bear_metric_all <= atr_val * zone_proximity_atr

liq_band = atr_val * liquidity_band_atr

low_cluster_hits = not na(major_low_ref) ? math.sum(math.abs(low - major_low_ref) <= liq_band ? 1.0 : 0.0, liquidity_lookback) : 0.0
high_cluster_hits = not na(major_high_ref) ? math.sum(math.abs(high - major_high_ref) <= liq_band ? 1.0 : 0.0, liquidity_lookback) : 0.0

bull_liq_density = f_clamp((low_cluster_hits - 1.0) / liq_density_norm, 0.0, 1.0)
bear_liq_density = f_clamp((high_cluster_hits - 1.0) / liq_density_norm, 0.0, 1.0)

//=====================================================
// Qualified Sweep Layer
//=====================================================
bull_minor_sweep = bull_minor_sweep_raw and (
    (not na(bull_minor_excursion_atr) and bull_minor_excursion_atr >= sweep_min_excursion_atr * qualified_minor_excursion_mult) or
    (bull_reclaim_body >= atr_val * sweep_reclaim_body_atr * qualified_minor_body_mult and ctf_eff >= eff_min) or
    (bull_proximity and bull_zone_quality >= min_survival_score)
)

bear_minor_sweep = bear_minor_sweep_raw and (
    (not na(bear_minor_excursion_atr) and bear_minor_excursion_atr >= sweep_min_excursion_atr * qualified_minor_excursion_mult) or
    (bear_reclaim_body >= atr_val * sweep_reclaim_body_atr * qualified_minor_body_mult and ctf_eff >= eff_min) or
    (bear_proximity and bear_zone_quality >= min_survival_score)
)

bull_sweep = bull_major_sweep or bull_minor_sweep
bear_sweep = bear_major_sweep or bear_minor_sweep

bars_since_bull_major_sweep = ta.barssince(bull_major_sweep)
bars_since_bear_major_sweep = ta.barssince(bear_major_sweep)
bars_since_bull_minor_sweep = ta.barssince(bull_minor_sweep)
bars_since_bear_minor_sweep = ta.barssince(bear_minor_sweep)

recent_bull_major_sweep = not na(bars_since_bull_major_sweep) and bars_since_bull_major_sweep <= setup_window
recent_bear_major_sweep = not na(bars_since_bear_major_sweep) and bars_since_bear_major_sweep <= setup_window
recent_bull_minor_sweep = not na(bars_since_bull_minor_sweep) and bars_since_bull_minor_sweep <= setup_window
recent_bear_minor_sweep = not na(bars_since_bear_minor_sweep) and bars_since_bear_minor_sweep <= setup_window

recent_bull_sweep = recent_bull_major_sweep or recent_bull_minor_sweep
recent_bear_sweep = recent_bear_major_sweep or recent_bear_minor_sweep

//=====================================================
// Re-arm / Leg Counters
//=====================================================
var bool long_armed = true
var bool short_armed = true
var int last_long_signal_bar = na
var int last_short_signal_bar = na
var int bull_leg_long_count = 0
var int bear_leg_short_count = 0

bull_leg_event = bull_major_sweep or bos_bull
bear_leg_event = bear_major_sweep or bos_bear

if bull_leg_event
    bull_leg_long_count := 0

if bear_leg_event
    bear_leg_short_count := 0

long_reset_condition = (
    (rearm_use_opposite_sweep and (recent_bear_major_sweep or recent_bear_minor_sweep)) or
    (rearm_use_ema_reset and close < ema_fast) or
    (rearm_use_disp_reset and bear_disp)
)

short_reset_condition = (
    (rearm_use_opposite_sweep and (recent_bull_major_sweep or recent_bull_minor_sweep)) or
    (rearm_use_ema_reset and close > ema_fast) or
    (rearm_use_disp_reset and bull_disp)
)

if long_reset_condition
    long_armed := true

if short_reset_condition
    short_armed := true

long_cooldown_ok = na(last_long_signal_bar) or bar_index - last_long_signal_bar > signal_cooldown_bars
short_cooldown_ok = na(last_short_signal_bar) or bar_index - last_short_signal_bar > signal_cooldown_bars

//=====================================================
// Acceptance / Rejection
//=====================================================
bull_rejection_score = 0.0
bull_acceptance_penalty = 0.0
if bull_proximity and not na(near_bull_ref_all)
    bull_rejection_score += low <= near_bull_ref_all and close > near_bull_ref_all ? 1.0 : 0.0
    bull_rejection_score += bull_reclaim_body >= atr_val * sweep_reclaim_body_atr ? 0.5 : 0.0
    bull_rejection_score += volume > vol_ma * vol_mult ? 0.25 : 0.0
    bull_acceptance_penalty += close < near_bull_ref_all and bear_disp ? 0.75 : 0.0
    bull_acceptance_penalty += close < near_bull_ref_all and volume > vol_ma * vol_mult ? 0.25 : 0.0

bear_rejection_score = 0.0
bear_acceptance_penalty = 0.0
if bear_proximity and not na(near_bear_ref_all)
    bear_rejection_score += high >= near_bear_ref_all and close < near_bear_ref_all ? 1.0 : 0.0
    bear_rejection_score += bear_reclaim_body >= atr_val * sweep_reclaim_body_atr ? 0.5 : 0.0
    bear_rejection_score += volume > vol_ma * vol_mult ? 0.25 : 0.0
    bear_acceptance_penalty += close > near_bear_ref_all and bull_disp ? 0.75 : 0.0
    bear_acceptance_penalty += close > near_bear_ref_all and volume > vol_ma * vol_mult ? 0.25 : 0.0

//=====================================================
// Hazard-style Zone Failure
//=====================================================
bull_fill_risk = nz(near_bull_fill_all, 0.0)
bear_fill_risk = nz(near_bear_fill_all, 0.0)
bull_touch_risk = f_clamp(nz(near_bull_touches_all, 0.0) / hazard_touch_norm, 0.0, 1.0)
bear_touch_risk = f_clamp(nz(near_bear_touches_all, 0.0) / hazard_touch_norm, 0.0, 1.0)

bull_zone_hazard = f_clamp(
    hazard_survival_weight * (1.0 - bull_zone_quality) +
    hazard_fill_weight * bull_fill_risk +
    hazard_touch_weight * bull_touch_risk +
    hazard_accept_weight * f_clamp(bull_acceptance_penalty, 0.0, 1.0),
    0.0, 1.0
)

bear_zone_hazard = f_clamp(
    hazard_survival_weight * (1.0 - bear_zone_quality) +
    hazard_fill_weight * bear_fill_risk +
    hazard_touch_weight * bear_touch_risk +
    hazard_accept_weight * f_clamp(bear_acceptance_penalty, 0.0, 1.0),
    0.0, 1.0
)

bull_zone_stability = 1.0 - bull_zone_hazard
bear_zone_stability = 1.0 - bear_zone_hazard

//=====================================================
// Approach / Reaction Quality
//=====================================================
bull_grind_penalty = bull_proximity and close < close[1] and close[1] < close[2] and volume < vol_ma
bear_grind_penalty = bear_proximity and close > close[1] and close[1] > close[2] and volume < vol_ma

bull_sweep_score = bull_major_sweep ? 2.0 + bull_liq_density : bull_minor_sweep ? 0.85 + bull_liq_density * 0.35 : bull_minor_sweep_raw ? 0.20 : 0.0
bear_sweep_score = bear_major_sweep ? 2.0 + bear_liq_density : bear_minor_sweep ? 0.85 + bear_liq_density * 0.35 : bear_minor_sweep_raw ? 0.20 : 0.0

bull_approach_score = 0.0
bull_approach_score += recent_bull_major_sweep ? 2.0 : recent_bull_minor_sweep ? 0.85 : 0.0
bull_approach_score += bull_proximity ? 0.5 : 0.0
bull_approach_score += ctf_eff >= eff_min ? 0.50 : -0.25
bull_approach_score += bull_zone_quality > 0.70 ? 1.0 : bull_zone_quality > 0.50 ? 0.5 : bull_zone_quality < min_survival_score ? -1.0 : 0.0
bull_approach_score -= bull_grind_penalty ? 1.0 : 0.0
bull_approach_score += trend_clarity >= 0.45 ? 0.35 : -0.50

bear_approach_score = 0.0
bear_approach_score += recent_bear_major_sweep ? 2.0 : recent_bear_minor_sweep ? 0.85 : 0.0
bear_approach_score += bear_proximity ? 0.5 : 0.0
bear_approach_score += ctf_eff >= eff_min ? 0.50 : -0.25
bear_approach_score += bear_zone_quality > 0.70 ? 1.0 : bear_zone_quality > 0.50 ? 0.5 : bear_zone_quality < min_survival_score ? -1.0 : 0.0
bear_approach_score -= bear_grind_penalty ? 1.0 : 0.0
bear_approach_score += trend_clarity >= 0.45 ? 0.35 : -0.50

bull_reaction_score = 0.0
bull_reaction_score += any_bull_touch and close > open ? 1.0 : 0.0
bull_reaction_score += close > ema_fast ? 0.5 : -0.5
bull_reaction_score += bull_disp ? 1.0 : 0.0
bull_reaction_score += volume > vol_ma * vol_mult ? 0.5 : 0.0
bull_reaction_score += bull_sweep_score > 0 ? 0.25 : 0.0
bull_reaction_score += bull_rejection_score
bull_reaction_score += bull_disp_quality >= disp_quality_min ? 0.75 : bull_disp_quality >= 0.85 ? 0.30 : 0.0
bull_reaction_score -= bear_disp ? 1.0 : 0.0
bull_reaction_score -= bull_acceptance_penalty
bull_reaction_score -= not na(near_bull_ref_all) and close < near_bull_ref_all ? 0.50 : 0.0

bear_reaction_score = 0.0
bear_reaction_score += any_bear_touch and close < open ? 1.0 : 0.0
bear_reaction_score += close < ema_fast ? 0.5 : -0.5
bear_reaction_score += bear_disp ? 1.0 : 0.0
bear_reaction_score += volume > vol_ma * vol_mult ? 0.5 : 0.0
bear_reaction_score += bear_sweep_score > 0 ? 0.25 : 0.0
bear_reaction_score += bear_rejection_score
bear_reaction_score += bear_disp_quality >= disp_quality_min ? 0.75 : bear_disp_quality >= 0.85 ? 0.30 : 0.0
bear_reaction_score -= bull_disp ? 1.0 : 0.0
bear_reaction_score -= bear_acceptance_penalty
bear_reaction_score -= not na(near_bear_ref_all) and close > near_bear_ref_all ? 0.50 : 0.0

//=====================================================
// Zone Interaction Path
//=====================================================
bull_reclaim_path = recent_bull_sweep and bull_proximity and bull_rejection_score > 0
bear_reclaim_path = recent_bear_sweep and bear_proximity and bear_rejection_score > 0

bull_retest_path = bull_proximity and close > ema_fast and low <= nz(near_bull_ref_all, low)
bear_retest_path = bear_proximity and close < ema_fast and high >= nz(near_bear_ref_all, high)

bull_impulse_path = not na(ta.barssince(bull_disp)) and ta.barssince(bull_disp) <= 3 and bull_proximity
bear_impulse_path = not na(ta.barssince(bear_disp)) and ta.barssince(bear_disp) <= 3 and bear_proximity

bull_grind_path = bull_proximity and close < close[1] and close[1] < close[2] and ctf_eff < eff_min
bear_grind_path = bear_proximity and close > close[1] and close[1] > close[2] and ctf_eff < eff_min

bull_path_score = 0.0
bull_path_score += bull_reclaim_path ? path_reclaim_bonus : 0.0
bull_path_score += bull_retest_path ? path_retest_bonus : 0.0
bull_path_score += bull_impulse_path ? path_impulse_bonus : 0.0
bull_path_score -= bull_grind_path ? path_grind_penalty : 0.0
bull_path_score += bull_liq_density * 0.35
bull_path_score += bull_zone_stability * 0.35

bear_path_score = 0.0
bear_path_score += bear_reclaim_path ? path_reclaim_bonus : 0.0
bear_path_score += bear_retest_path ? path_retest_bonus : 0.0
bear_path_score += bear_impulse_path ? path_impulse_bonus : 0.0
bear_path_score -= bear_grind_path ? path_grind_penalty : 0.0
bear_path_score += bear_liq_density * 0.35
bear_path_score += bear_zone_stability * 0.35

//=====================================================
// Archetype Engine
//=====================================================
bull_impulse_event = bull_major_sweep or bos_bull or bull_disp
bear_impulse_event = bear_major_sweep or bos_bear or bear_disp

bars_since_bull_impulse = ta.barssince(bull_impulse_event)
bars_since_bear_impulse = ta.barssince(bear_impulse_event)

dist_fast_atr = atr_val > 0 ? math.abs(close - ema_fast) / atr_val : 0.0

long_late_penalty = 0.0
long_late_penalty += dist_fast_atr > late_dist_atr_act ? 1.0 : 0.0
long_late_penalty += in_premium ? 0.75 : 0.0
long_late_penalty += not na(bars_since_bull_impulse) and bars_since_bull_impulse > continuation_window_act ? 1.0 : 0.0
long_late_penalty += bull_leg_long_count > 0 ? 1.25 : 0.0

short_late_penalty = 0.0
short_late_penalty += dist_fast_atr > late_dist_atr_act ? 1.0 : 0.0
short_late_penalty += in_discount ? 0.75 : 0.0
short_late_penalty += not na(bars_since_bear_impulse) and bars_since_bear_impulse > continuation_window_act ? 1.0 : 0.0
short_late_penalty += bear_leg_short_count > 0 ? 1.25 : 0.0

continuation_long_ready = (
    ctf_bias == 1 and
    h4_bias == 1 and
    d_bias != -1 and
    bull_zone_quality >= zone_hard_gate_act and
    bull_proximity and
    not continuation_chop_block and
    not na(bars_since_bull_impulse) and
    bars_since_bull_impulse <= continuation_window_act and
    dist_fast_atr <= first_pullback_atr_act and
    bull_reaction_score >= continuation_react_min_act and
    bull_disp_quality >= disp_quality_min and
    bull_path_score >= 0.35 and
    bull_leg_long_count < max_longs_per_bull_leg_act and
    long_late_penalty <= 1.0
)

continuation_short_ready = (
    ctf_bias == -1 and
    h4_bias == -1 and
    d_bias != 1 and
    bear_zone_quality >= zone_hard_gate_act and
    bear_proximity and
    not continuation_chop_block and
    not na(bars_since_bear_impulse) and
    bars_since_bear_impulse <= continuation_window_act and
    dist_fast_atr <= first_pullback_atr_act and
    bear_reaction_score >= continuation_react_min_act and
    bear_disp_quality >= disp_quality_min and
    bear_path_score >= 0.35 and
    bear_leg_short_count < max_shorts_per_bear_leg_act and
    short_late_penalty <= 1.0
)

reversal_long_ready = (
    (recent_bull_major_sweep or (recent_bull_minor_sweep and bull_liq_density >= liq_minor_reversal_min)) and
    bull_zone_quality >= zone_hard_gate_act and
    bull_zone_stability >= 0.35 and
    (bull_rejection_score + bull_liq_density * 0.75) >= reversal_reject_min_act and
    bull_acceptance_penalty <= 0.25 and
    bull_path_score >= 0.20 and
    in_discount and
    h4_bias != -1 and
    d_bias != -1
)

reversal_short_ready = (
    (recent_bear_major_sweep or (recent_bear_minor_sweep and bear_liq_density >= liq_minor_reversal_min)) and
    bear_zone_quality >= zone_hard_gate_act and
    bear_zone_stability >= 0.35 and
    (bear_rejection_score + bear_liq_density * 0.75) >= reversal_reject_min_act and
    bear_acceptance_penalty <= 0.25 and
    bear_path_score >= 0.20 and
    in_premium and
    h4_bias != 1 and
    d_bias != 1
)

long_reversal_score = 0.0
long_reversal_score += bull_zone_quality * 2.0
long_reversal_score += bull_zone_stability * 1.4
long_reversal_score += bull_rejection_score * 1.5
long_reversal_score += bull_liq_density * 1.0
long_reversal_score += bull_path_score * 1.2
long_reversal_score += recent_bull_major_sweep ? 1.8 : recent_bull_minor_sweep ? 0.65 : 0.0
long_reversal_score += in_discount ? 1.0 : 0.0
long_reversal_score += long_regime_score
long_reversal_score += is_eth ? (eth_filter_long ? 1.0 : -2.0) : 0.0
long_reversal_score -= bull_acceptance_penalty
long_reversal_score -= bull_zone_hazard * 1.1
long_reversal_score -= long_late_penalty * 0.4

short_reversal_score = 0.0
short_reversal_score += bear_zone_quality * 2.0
short_reversal_score += bear_zone_stability * 1.4
short_reversal_score += bear_rejection_score * 1.5
short_reversal_score += bear_liq_density * 1.0
short_reversal_score += bear_path_score * 1.2
short_reversal_score += recent_bear_major_sweep ? 1.8 : recent_bear_minor_sweep ? 0.65 : 0.0
short_reversal_score += in_premium ? 1.0 : 0.0
short_reversal_score += short_regime_score
short_reversal_score += is_eth ? (eth_filter_short ? 1.0 : -2.0) : 0.0
short_reversal_score -= bear_acceptance_penalty
short_reversal_score -= bear_zone_hazard * 1.1
short_reversal_score -= short_late_penalty * 0.4

long_continuation_score = 0.0
long_continuation_score += bull_zone_quality * 1.8
long_continuation_score += bull_zone_stability * 1.2
long_continuation_score += bull_approach_score
long_continuation_score += bull_reaction_score
long_continuation_score += bull_path_score * 0.9
long_continuation_score += long_regime_score
long_continuation_score += continuation_long_ready ? 1.5 : 0.0
long_continuation_score += is_eth ? (eth_filter_long ? 1.0 : -2.0) : 0.0
long_continuation_score -= bull_zone_hazard * 0.9
long_continuation_score -= long_late_penalty

short_continuation_score = 0.0
short_continuation_score += bear_zone_quality * 1.8
short_continuation_score += bear_zone_stability * 1.2
short_continuation_score += bear_approach_score
short_continuation_score += bear_reaction_score
short_continuation_score += bear_path_score * 0.9
short_continuation_score += short_regime_score
short_continuation_score += continuation_short_ready ? 1.5 : 0.0
short_continuation_score += is_eth ? (eth_filter_short ? 1.0 : -2.0) : 0.0
short_continuation_score -= bear_zone_hazard * 0.9
short_continuation_score -= short_late_penalty

long_mode_reversal = reversal_long_ready and long_reversal_score >= min_entry_score_act
long_mode_continuation = continuation_long_ready and long_continuation_score >= min_entry_score_act
short_mode_reversal = reversal_short_ready and short_reversal_score >= min_entry_score_act
short_mode_continuation = continuation_short_ready and short_continuation_score >= min_entry_score_act

//=====================================================
// Risk / RR Proxy
//=====================================================
long_sl = math.min(low, nz(last_swing_low, low)) - atr_val * 0.25
short_sl = math.max(high, nz(last_swing_high, high)) + atr_val * 0.25

long_risk = close - long_sl
short_risk = short_sl - close

long_target_proxy = not na(near_bear_ref_all) and near_bear_ref_all > close ? near_bear_ref_all : close + long_risk * 2.2
short_target_proxy = not na(near_bull_ref_all) and near_bull_ref_all < close ? near_bull_ref_all : close - short_risk * 2.2

rr_long = long_risk > syminfo.mintick ? (long_target_proxy - close) / long_risk : na
rr_short = short_risk > syminfo.mintick ? (close - short_target_proxy) / short_risk : na

rr_long_ok_act = not na(rr_long) and rr_long >= min_rr_act
rr_short_ok_act = not na(rr_short) and rr_short >= min_rr_act

long_quality_core = 0.24 * bull_zone_stability + 0.16 * bull_liq_density + 0.16 * f_clamp(bull_disp_quality / 2.0, 0.0, 1.0) + 0.14 * trend_clarity + 0.14 * f_clamp((long_regime_score + 1.5) / 4.0, 0.0, 1.0) + 0.16 * f_clamp((bull_path_score + 1.0) / 3.0, 0.0, 1.0)
short_quality_core = 0.24 * bear_zone_stability + 0.16 * bear_liq_density + 0.16 * f_clamp(bear_disp_quality / 2.0, 0.0, 1.0) + 0.14 * trend_clarity + 0.14 * f_clamp((short_regime_score + 1.5) / 4.0, 0.0, 1.0) + 0.16 * f_clamp((bear_path_score + 1.0) / 3.0, 0.0, 1.0)

long_pwin_proxy = 1.0 / (1.0 + math.exp(-ev_sigmoid_slope * (long_quality_core - 0.50)))
short_pwin_proxy = 1.0 / (1.0 + math.exp(-ev_sigmoid_slope * (short_quality_core - 0.50)))

long_reward_proxy = not na(rr_long) ? math.max(rr_long, 0.0) : na
short_reward_proxy = not na(rr_short) ? math.max(rr_short, 0.0) : na

long_risk_proxy = 1.0 + bull_zone_hazard * 1.1 + compression_score * 0.7 + long_late_penalty * 0.35
short_risk_proxy = 1.0 + bear_zone_hazard * 1.1 + compression_score * 0.7 + short_late_penalty * 0.35

ev_long = not na(long_reward_proxy) ? long_pwin_proxy * long_reward_proxy - (1.0 - long_pwin_proxy) * long_risk_proxy : na
ev_short = not na(short_reward_proxy) ? short_pwin_proxy * short_reward_proxy - (1.0 - short_pwin_proxy) * short_risk_proxy : na

ev_long_ok = not na(ev_long) and ev_long >= ev_min_act
ev_short_ok = not na(ev_short) and ev_short >= ev_min_act

//=====================================================
// Final Signals
//=====================================================
long_signal_raw = (
    barstate.isconfirmed and
    long_armed and
    long_cooldown_ok and
    rr_long_ok_act and
    ev_long_ok and
    bull_zone_quality >= zone_hard_gate_act and
    ((long_mode_reversal and long_reversal_score >= min_entry_score_act) or (long_mode_continuation and long_continuation_score >= min_entry_score_act))
)

short_signal_raw = (
    barstate.isconfirmed and
    short_armed and
    short_cooldown_ok and
    rr_short_ok_act and
    ev_short_ok and
    bear_zone_quality >= zone_hard_gate_act and
    ((short_mode_reversal and short_reversal_score >= min_entry_score_act) or (short_mode_continuation and short_continuation_score >= min_entry_score_act))
)

long_signal = long_signal_raw and not long_signal_raw[1]
short_signal = short_signal_raw and not short_signal_raw[1] and not long_signal

if long_signal
    last_long_signal_bar := bar_index
    long_armed := false
    bull_leg_long_count := bull_leg_long_count + 1

if short_signal
    last_short_signal_bar := bar_index
    short_armed := false
    bear_leg_short_count := bear_leg_short_count + 1

//=====================================================
// Visuals
//=====================================================
plot(ema_fast, "EMA Fast", color=color.orange, linewidth=2)
plot(ema_slow, "EMA Slow", color=color.blue, linewidth=2)
plot(show_eq_line ? eq_line : na, "EQ", color=color.new(color.yellow, 5), linewidth=1)

bgcolor(
    show_bg_bias ?
    (h4_bias == 1 and d_bias == 1 ? color.new(color.green, 93) :
     h4_bias == -1 and d_bias == -1 ? color.new(color.red, 93) : na)
    : na
)

plotshape(show_small_signals and long_signal, title="Long Small", style=shape.triangleup, location=location.belowbar, size=size.tiny, color=color.lime, text="L")
plotshape(show_small_signals and short_signal, title="Short Small", style=shape.triangledown, location=location.abovebar, size=size.tiny, color=color.red, text="S")

plotshape(show_major_sweeps and bull_major_sweep, title="Bull Major Sweep", style=shape.circle, location=location.belowbar, size=size.tiny, color=color.new(color.green, 0), text="MSWP")
plotshape(show_major_sweeps and bear_major_sweep, title="Bear Major Sweep", style=shape.circle, location=location.abovebar, size=size.tiny, color=color.new(color.red, 0), text="MSWP")

plotshape(show_qualified_minor_sweeps and bull_minor_sweep and not bull_major_sweep, title="Bull Qualified Minor Sweep", style=shape.circle, location=location.belowbar, size=size.tiny, color=color.new(color.green, 15), text="SWP")
plotshape(show_qualified_minor_sweeps and bear_minor_sweep and not bear_major_sweep, title="Bear Qualified Minor Sweep", style=shape.circle, location=location.abovebar, size=size.tiny, color=color.new(color.red, 15), text="SWP")

plotshape(show_raw_minor_sweeps and bull_minor_sweep_raw and not bull_minor_sweep and not bull_major_sweep, title="Bull Raw Minor Sweep", style=shape.circle, location=location.belowbar, size=size.tiny, color=color.new(color.green, 55), text="m")
plotshape(show_raw_minor_sweeps and bear_minor_sweep_raw and not bear_minor_sweep and not bear_major_sweep, title="Bear Raw Minor Sweep", style=shape.circle, location=location.abovebar, size=size.tiny, color=color.new(color.red, 55), text="m")

if show_big_labels and long_signal
    _long_mode = long_mode_reversal ? "REV" : long_mode_continuation ? "CONT" : "NA"
    _long_score = long_mode_reversal ? long_reversal_score : long_continuation_score
    label.new(
         bar_index,
         low,
         "LONG " + _long_mode +
         "\nScore: " + str.tostring(_long_score, "#.##") +
         "\nSurv: " + str.tostring(bull_zone_quality, "#.##") +
         "\nHaz: " + str.tostring(bull_zone_hazard, "#.##") +
         "\nPath: " + str.tostring(bull_path_score, "#.##") +
         "\nLiq: " + str.tostring(bull_liq_density, "#.##") +
         "\nDispQ: " + str.tostring(bull_disp_quality, "#.##") +
         "\nResidZ: " + str.tostring(resid_z, "#.##") +
         "\nEV: " + str.tostring(ev_long, "#.##") +
