plotshape(show_trend and entrySignal, location=location.belowbar, style=shape.triangleup, text="E", color=color.new(color.green, 0), textcolor=color.black, size=size.tiny)
plotshape(show_short and exitMajorSignal, location=location.abovebar, style=shape.triangledown, text="X", color=color.new(color.red, 0), textcolor=color.black, size=size.tiny)

candle_reversal_color = exitMajorSignal or inRiskOff or inShortBias ? color.new(color.red, 0) : entrySignal or inLongBias ? color.new(color.lime, 0) : na
